    <div class="font-semibold text-stone-400">ExtraLenses</div>
    <nav class="flex flex-wrap gap-6 justify-center">
      <a href="/docs" class="hover:text-stone-300 transition-colors">Docs <span class="text-stone-700">(coming soon)</span></a>
      <a href="https://github.com/extralenses" class="hover:text-stone-300 transition-colors">GitHub <span class="text-stone-700">(coming soon)</span></a>
      <a href="/privacy" class="hover:text-stone-300 transition-colors">Privacy</a>
      <a href="mailto:hello@extralenses.com" class="hover:text-stone-300 transition-colors">Contact</a>
