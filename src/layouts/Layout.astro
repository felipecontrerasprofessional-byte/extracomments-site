---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonicalURL?: string;
}

const {
  title = 'ExtraLenses — Self-Hosted Perspective API Replacement',
  description = 'Drop-in self-hosted replacement for Perspective API. Sentence-level moderation for Artalk, Remark42, and custom comment systems. Ships December 2026.',
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
} = Astro.props;

const ogImage = new URL('/og-image.png', Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Umami Analytics -->
    <script defer src="https://cloud.umami.is/script.js" data-website-id="af6c4875-de50-48e2-8ec2-b7ee14d971cb"></script>

    <!-- Organization structured data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "ExtraLenses",
        "url": "https://extralenses.com",
        "description": "Self-hosted Perspective API replacement with sentence-level moderation"
      }
    </script>
  </head>
  <body class="bg-stone-950 text-stone-100 font-sans antialiased">
    <slot />
  </body>
</html>
