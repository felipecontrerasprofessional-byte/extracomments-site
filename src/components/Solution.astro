---
const features = [
  {
    icon: '⇄',
    title: 'Drop-in API compatibility',
    description:
      'Swap Perspective API endpoints. No code changes to your moderation logic.',
  },
  {
    icon: '◉',
    title: 'Sentence-level precision',
    description:
      'Tags individual sentences, not whole comments. Better signal, fewer false positives.',
  },
  {
    icon: '⬡',
    title: 'Self-hosted, Docker Compose',
    description:
      'Your data, your infrastructure. One command to deploy.',
  },
];
---
<section id="how-it-works" class="px-6 py-16 max-w-5xl mx-auto">
  <h2 class="text-2xl sm:text-3xl font-serif font-bold text-stone-50 text-center mb-12">
    How it works
  </h2>
  <div class="grid sm:grid-cols-3 gap-8">
    {features.map((f) => (
      <div class="bg-stone-900 border border-stone-800 rounded-xl p-6">
        <div class="text-2xl mb-4 text-amber-400">{f.icon}</div>
        <h3 class="text-stone-50 font-semibold text-lg mb-2">{f.title}</h3>
        <p class="text-stone-400 leading-relaxed">{f.description}</p>
      </div>
    ))}
  </div>
</section>
