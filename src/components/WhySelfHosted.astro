---
const reasons = [
  {
    title: 'Data sovereignty',
    description:
      'Comment text never leaves your infrastructure. No third-party processor agreements required for GDPR compliance on your readers\u2019 data.',
  },
  {
    title: 'No per-call billing',
    description:
      "Flat annual pricing regardless of comment volume. A traffic spike doesn't become an invoice surprise.",
  },
  {
    title: 'No vendor lockout risk',
    description:
      "You've already experienced what happens when a vendor shuts down. Self-hosted means you own the runtime — no sunset risk.",
  },
];
---
<section class="px-6 py-16 bg-stone-900/50">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl sm:text-3xl font-serif font-bold text-stone-50 text-center mb-12">
      Why self-hosted matters
    </h2>
    <div class="grid sm:grid-cols-3 gap-8">
      {reasons.map((r) => (
        <div>
          <h3 class="text-stone-50 font-semibold text-lg mb-2">{r.title}</h3>
          <p class="text-stone-400 leading-relaxed">{r.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
